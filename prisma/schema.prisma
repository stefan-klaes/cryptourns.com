generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  ERC721
  ERC1155
  ERC20
}

enum AssetTransferDirection {
  IN
  OUT
}

model Candle {
  urnId     Int
  address   String
  createdAt DateTime @default(now())

  urn Urn @relation(fields: [urnId], references: [id], onDelete: Cascade)

  @@id([urnId, address])
  @@index([urnId])
}

model Asset {
  id               Int       @id @default(autoincrement())
  urnId            Int
  contractAddress  String
  tokenId          String
  type             AssetType
  quantity         Int
  name             String?
  imageUrl         String?
  collectionName   String?
  sentToUrn        DateTime?
  createdAt        DateTime  @default(now())

  urn Urn @relation(fields: [urnId], references: [id], onDelete: Cascade)

  @@unique([urnId, contractAddress, tokenId])
  @@index([urnId])
  @@index([contractAddress, type, tokenId])
}

model Urn {
  id        Int      @id
  tba       String   @unique
  cracked   Boolean  @default(false)
  mintTx    String
  mintedAt  DateTime
  mintedBy  String
  /// Highest chain block fully ingested for `UrnAssetTransfer` sync (incremental `fromBlock` cursor).
  assetTransfersSyncedThroughBlock Int @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  candles           Candle[]
  assets            Asset[]
  assetTransfers    UrnAssetTransfer[]
}

model UrnAssetTransfer {
  id Int @id @default(autoincrement())

  urnId Int
  urn   Urn @relation(fields: [urnId], references: [id], onDelete: Cascade)

  direction  AssetTransferDirection
  assetType  AssetType

  blockNumber Int
  occurredAt  DateTime?

  txHash   String
  logIndex Int

  fromAddress String
  toAddress   String

  contractAddress String
  tokenId         String

  quantityRaw     String
  quantityDisplay String?

  assetSymbol String?
  decimals    Int?

  name           String?
  imageUrl       String?
  collectionName String?

  alchemyUniqueId String?

  createdAt DateTime @default(now())

  @@unique([urnId, txHash, logIndex, contractAddress, tokenId, direction])
  @@index([urnId, occurredAt(sort: Desc)])
  @@index([urnId, blockNumber])
}
