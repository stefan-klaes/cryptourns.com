generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  ERC721
  ERC1155
  ERC20
}

model Candle {
  urnId     Int
  address   String
  createdAt DateTime @default(now())

  urn Urn @relation(fields: [urnId], references: [id], onDelete: Cascade)

  @@id([urnId, address])
  @@index([urnId])
}

model Asset {
  id               Int       @id @default(autoincrement())
  urnId            Int
  contractAddress  String
  tokenId          String
  type             AssetType
  quantity         Int
  createdAt        DateTime  @default(now())

  urn Urn @relation(fields: [urnId], references: [id], onDelete: Cascade)

  @@unique([urnId, contractAddress, tokenId])
  @@index([urnId])
}

model Urn {
  id        Int      @id
  tba       String   @unique
  cracked   Boolean  @default(false)
  mintTx    String
  mintedAt  DateTime
  mintedBy  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  candles Candle[]
  assets  Asset[]
}
